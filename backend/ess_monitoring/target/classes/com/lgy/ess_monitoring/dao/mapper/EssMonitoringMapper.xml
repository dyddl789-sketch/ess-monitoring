	<select id="getData" resultType="com.lgy.ess_monitoring.dto.EssMonitoringDTO">
    select ess_id, member_id, device_name, voltage, current_val, soc, status, measured_at
    from ess_monitoring
    where member_id = #{param1}
    order by measured_at desc
	</select>
	
	<select id="getDbUser" resultType="string">
    select user from dual
	</select>

	<select id="getTotalCount" resultType="int">
	    select count(*) from ess_monitoring
	</select>
	
	<select id="getMemberCount" resultType="int">
	    select count(*) from ess_monitoring where member_id = 1
	</select>

</mapper>





























