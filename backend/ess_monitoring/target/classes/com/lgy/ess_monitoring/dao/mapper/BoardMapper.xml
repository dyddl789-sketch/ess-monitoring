<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lgy.ess_monitoring.dao.BoardDAO"> 
	<!-- 검색 조건 -->
    <sql id="criteria">
        <if test="type != null and keyword != null and keyword != ''">
            <trim prefix="and (" suffix=")">
                <foreach item="t" collection="typeArr" separator="or">
                    <choose>
                        <!-- 제목 검색 -->
                        <when test='t == "T"'>
                            b.board_title like concat('%', #{keyword}, '%')
                        </when>

                        <!-- 내용 검색 -->
                        <when test='t == "C"'>
                            b.board_content like concat('%', #{keyword}, '%')
                        </when>

                        <!-- 작성자 검색 -->
                        <when test='t == "W"'>
                            m.member_name like concat('%', #{keyword}, '%')
                        </when>
                    </choose>
                </foreach>
            </trim>
        </if>
    </sql>
	
	
	<!-- 전체 목록 -->
    <select id="list" resultType="com.lgy.ess_monitoring.dto.BoardDTO">
		select b.board_no,
               b.member_id,
               m.member_name,
               b.board_title,
               b.board_content,
               b.board_hit,
               b.created_at,
               b.updated_at
          from board b join ess_member m on b.member_id = m.member_id
         order by b.board_no desc    
    </select>
    
    <select id="getWriterMemberId" parameterType="int" resultType="int">
	    select member_id
	    from board
	    where board_no = #{value}
	</select>
    
	<!-- 페이징 + 검색 목록 -->
    <select id="listWithPaging" 
    		parameterType="com.lgy.ess_monitoring.dto.Criteria"
    		resultType="com.lgy.ess_monitoring.dto.BoardDTO">
        select b.board_no,
               b.member_id,
               m.member_name,
               b.board_title,
               b.board_content,
               b.board_hit,
               b.created_at,
               b.updated_at
          from board b join ess_member m on b.member_id = m.member_id
          <!-- 검색 조건 -->
    <where>
        <!-- 검색어가 있을 때만 검색 조건 적용 -->
        <if test="keyword != null and keyword != ''">

            <!--
                검색 조건을 괄호로 묶음
                예: AND (b.board_title LIKE '%ess%')
            -->
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">

                <!--
                    Criteria의 getTypeArr() 결과를 반복
                    type = T  → 제목
                    type = C  → 내용
                    type = W  → 작성자
                    type = TC → 제목 OR 내용
                -->
                <foreach collection="typeArr" item="type">

                    <!-- 제목 검색 -->
                    <if test="type == 'T'">
                        OR b.board_title LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                    <!-- 내용 검색 -->
                    <if test="type == 'C'">
                        OR b.board_content LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                    <!-- 작성자 검색 -->
                    <if test="type == 'W'">
                        OR m.member_name LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                </foreach>
            </trim>
        </if>
    </where>

    <!-- 최신 글 순서 -->
    ORDER BY b.board_no DESC

    <!-- 한 페이지에 보여줄 개수 -->
    LIMIT #{amount}

    <!-- 앞에서 건너뛸 개수 -->
    OFFSET #{pageStart}
    </select>
    
	<!-- 글쓰기 -->
    <insert id="write" parameterType="hashmap">
		insert into board(member_id, board_title, board_content) values( #{member_id},#{board_title},#{board_content})
    </insert>
    
	<!-- 상세보기 -->
    <select id="contentView" resultType="com.lgy.ess_monitoring.dto.BoardDTO">
       select b.board_no,
              b.member_id,
              m.member_name,
              b.board_title,
              b.board_content,
              b.board_hit,
              b.created_at,
              b.updated_at
         from board b
         join ess_member m on b.member_id = m.member_id
        where b.board_no = #{boardNo}
    </select>
    
	<!-- 수정 -->
    <update id="modify">
    	update board set
               board_title = #{board_title},
               board_content = #{board_content}
         where board_no = #{boardNo}
    </update>
    
	<!-- 삭제 -->
    <delete id="delete">
 		delete from board where board_no = #{board_no}
    </delete>

	<!-- 검색 조건 포함 전체 개수 -->
	<select id="getTotalCount" 
			resultType="int"
			parameterType="com.lgy.ess_monitoring.dto.Criteria">
        select count(*)
        from board b
        join ess_member m on b.member_id = m.member_id
        <where>
        <if test="keyword != null and keyword != ''">
            <trim prefix="AND (" suffix=")" prefixOverrides="OR">
                <foreach collection="typeArr" item="type">

                    <if test="type == 'T'">
                        OR b.board_title LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                    <if test="type == 'C'">
                        OR b.board_content LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                    <if test="type == 'W'">
                        OR m.member_name LIKE CONCAT('%', #{keyword}, '%')
                    </if>

                </foreach>
            </trim>
        </if>
    </where>
    </select>
    
	<!-- 전체 게시글 수 -->
	<update id="increaseHit">
        update board
        set board_hit = board_hit + 1
        where board_no = #{boardNo}
    </update>    
    
</mapper>





























