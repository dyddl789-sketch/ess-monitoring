/*  약관 동의 페이지 스타일  */
/* 약관 컨테이너 폭 확장 */
.consent-container { 
    max-width: 900px; /* 기존 700px에서 900px로 대폭 확장 */
    width: 95%; /* 모바일 대응을 위해 너비 비율 유지 */
    margin: 0 auto; 
    padding: 50px; /* 내부 여백을 더 줘서 답답함을 해소 */
    background: #fff; 
    border-radius: 12px; 
    box-shadow: 0 15px 40px rgba(0,0,0,0.1); 
}

/* 약관 텍스트 박스 높이 및 글꼴 최적화 */
.terms-text { 
    height: 250px; /* 높이도 120px에서 250px로 확장하여 시야 확보 */
    overflow-y: scroll; 
    border: 1px solid #e1e1e1; 
    padding: 20px; 
    font-size: 0.95rem; /* 글자 크기를 살짝 키워 가독성 향상 */
    color: #444; 
    background: #fdfdfd; 
    margin-bottom: 15px;
    line-height: 1.8; /* 줄 간격을 넓혀 눈의 피로도 감소 */
    border-radius: 8px;
    text-align: justify; /* 텍스트 양끝 정렬로 정갈하게 배치 */
}

/* 스크롤바 디자인 (세련되게 추가) */
.terms-text::-webkit-scrollbar {
    width: 8px;
}
.terms-text::-webkit-scrollbar-thumb {
    background-color: #ccc;
    border-radius: 10px;
}
