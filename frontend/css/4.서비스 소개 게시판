
/* -------- 서비스 소개 페이지 스타일 ----------- */
.sub-hero {
    background: #2c3e50; /* 비즈니스 블루 그레이 */
    color: #fff;
    padding: 40px 0;
    text-align: center;
}

.sub-hero h2 { font-size: 2.5rem; margin-bottom: 10px; }

.about-section {
    padding: 60px 0;
    text-align: center;
}

.about-text h3 {
    font-size: 2rem;
    margin-bottom: 20px;
    color: #007bff;
}

.about-text p {
    max-width: 1000px;
    margin: 0 auto;
    font-size: 1.1rem;
    color: #666;
}

.features-bg {
    background: #f4f7f9;
    padding: 80px 0;
}

.features-grid {
    display: flex;
    gap: 30px;
    justify-content: space-between;
}

.feature-item {
    flex: 1;
    background: #fff;
    padding: 40px 20px;
    border-radius: 15px;
    text-align: center;
    transition: transform 0.3s ease;
}

.feature-item:hover {
    transform: translateY(-10px); /* 살짝 올라가는 효과 */
}

.f-icon {
    font-size: 3rem;
    margin-bottom: 15px;
}

.feature-item h4 {
    margin-bottom: 10px;
    font-size: 1.2rem;
}

