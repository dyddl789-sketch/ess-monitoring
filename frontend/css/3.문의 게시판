
/* --------문의 게시판 폼 스타일 -----------*/
.contact-form-container {
    max-width: 600px;
    margin: 0 auto;
    background: #fdfdfd;
    padding: 40px;
    border: 1px solid #eee;
    border-radius: 10px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 5px;
    font-weight: bold;
}

.form-group input, 
.form-group textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 1rem;
}

.form-group textarea {
    resize: none; /* 크기 조절 방지 */
}


/* 주의사항 문구 영역의 여백 조정 */
div[style*="background: #fff3f3"] {
    margin: 0 !important;
    padding: 15px 0 !important; /* 위아래 간격을 균일하게 */
}

/* 문의 폼 컨테이너와 너비를 맞춘 주의사항 박스 */
.warning-box {
    max-width: 600px;         /* 폼 컨테이너와 동일한 너비 */
    margin: 20px auto 0;      /* 위쪽 간격 20px, 좌우 중앙 정렬 */
    background: #fff3f3;      /* 연한 빨간색 배경 */
    padding: 20px;            /* 내부 여백 */
    border: 1px solid #ffcccc; /* 테두리도 배경보다 조금 더 진하게 */
    border-radius: 10px;      /* 폼과 통일감을 주는 둥근 모서리 */
    text-align: center;       /* 텍스트 중앙 정렬 */
    box-sizing: border-box;   /* 너비 계산 오류 방지 */
}

.warning-box p {
    margin: 0;
    font-size: 0.95rem;
    color: #333;
}
