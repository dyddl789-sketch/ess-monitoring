/* [1] 섹션 전환 로직 (가장 중요: 까만 화면 해결책) */
.content-section { 
    display: none; /* 기본적으로 모든 섹션 숨김 */
    width: 100%;
} 

.content-section.active { 
    display: flex; /* active 클래스가 붙은 섹션만 표시 */
    flex-direction: column; 
    gap: 20px; 
    animation: fadeIn 0.3s ease; /* 전환 시 부드러운 효과 */
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
}

/* [2] 시스템 상태(관제) 섹션 스타일 */
.status-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 15px;
    margin-top: 25px;
}

.status-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 25px;
    text-align: left;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--text-sub);
    min-width: 60px;
}

.color-box {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: var(--gray-off);
    transition: all 0.3s ease;
}

.box-normal.active { background: #48bb78; box-shadow: 0 0 10px rgba(72, 187, 120, 0.6); }
.box-common.active { background: #3498db; box-shadow: 0 0 10px rgba(52, 152, 219, 0.6); }
.box-warn.active   { background: #f6ad55; box-shadow: 0 0 10px rgba(246, 173, 85, 0.6); }
.box-fault.active  { background: #f56565; box-shadow: 0 0 10px rgba(245, 101, 101, 0.6); }

/* [3] 리포트 게시판(설정 탭) 스타일 */
.report-table { 
    width: 100%; 
    border-collapse: collapse; 
    color: var(--text-main); 
    background: rgba(255, 255, 255, 0.02);
    border-radius: 8px;
    overflow: hidden;
}

.report-table th { 
    background: var(--bg-sidebar); 
    padding: 15px; 
    border-bottom: 2px solid var(--border); 
    font-size: 0.9rem; 
    font-weight: 600;
    color: var(--accent);
}

.report-table td { 
    padding: 15px; 
    text-align: center; 
    border-bottom: 1px solid var(--border); 
    font-size: 0.85rem; 
}

.report-table tr:hover { 
    background: var(--table-hover); 
}

/* 다운로드 버튼 (네온 스타일) */
.btn-neon-small {
    display: inline-block;
    padding: 6px 16px; 
    border: 1px solid var(--accent); 
    color: var(--accent);
    border-radius: 4px; 
    text-decoration: none; 
    font-size: 0.8rem; 
    font-weight: bold;
    transition: all 0.2s ease;
    cursor: pointer;
}

.btn-neon-small:hover { 
    background: var(--accent); 
    color: #0b1426; /* 배경색에 맞춰 글자색 반전 */
    box-shadow: 0 0 15px var(--accent);
}

/* [4] 제어 이력 로그 스타일 */
.log-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.8rem;
}

.content-section.active {
    display: flex;
    flex-direction: column; /* 카드들이 위아래로 배치됨 */
    gap: 20px;
}

/* 게시판 테이블 스타일 (기존 코드 유지) */
.report-table { width: 100%; border-collapse: collapse; }
.report-table th { background: var(--bg-sidebar); padding: 12px; border-bottom: 2px solid var(--border); }
.report-table td { padding: 15px; text-align: center; border-bottom: 1px solid var(--border); }
