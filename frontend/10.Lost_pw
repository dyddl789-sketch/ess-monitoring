<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>비밀번호 찾기 - ESS-M.S</title>
    <link rel="stylesheet" href="css/1.main.css">
    <style>
        .find-pw-page {
            background-color: #f4f7f9;
            min-height: calc(100vh - 70px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 0;
        }
        .find-pw-container {
            max-width: 450px;
            width: 90%;
            background: #fff;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            text-align: center;
        }
        .find-pw-header h2 {
            font-size: 1.8rem;
            color: #2c3e50;
            margin-bottom: 10px;
        }
        .find-pw-header p {
            color: #7f8c8d;
            font-size: 0.9rem;
            margin-bottom: 30px;
        }
        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }
        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 0.9rem;
        }
        .input-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 1rem;
        }
        .btn-full {
            width: 100%;
            padding: 14px;
            font-size: 1rem;
            margin-top: 10px;
        }
        .back-to-login {
            margin-top: 20px;
            display: block;
            color: #3498db;
            text-decoration: none;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <main class="find-pw-page">
        <div class="find-pw-container">
            <div class="find-pw-header">
                <h2>비밀번호 찾기</h2>
                <p>가입하신 이메일 주소를 입력하시면<br>비밀번호 재설정 안내를 보내드립니다.</p>
            </div>

            <form id="findPwForm" onsubmit="handleFindPw(event)">
                <div class="input-group">
                    <label for="userEmail">이메일 주소</label>
                    <input type="email" id="userEmail" placeholder="example@ess-ms.com" required>
                </div>
                <button type="submit" class="btn btn-full">인증 메일 보내기</button>
            </form>

            <a href="javascript:void(0)" onclick="window.close()" class="back-to-login">로그인 화면으로 돌아가기</a>
        </div>
    </main>

    <script>
        function handleFindPw(event) {
            event.preventDefault();
            const email = document.getElementById('userEmail').value;

            // 실제 백엔드 연동 시 여기에 API 호출 로직이 들어갑니다.
            alert(email + " 주소로 인증 메일을 발송했습니다.\n메일함을 확인해 주세요.");
            
            // 팝업 창일 경우 자동으로 닫거나 메인으로 이동
            if (window.opener) {
                // window.close();
            } else {
                location.href = '1.main.html';
            }
        }
    </script>
</body>
</html>
