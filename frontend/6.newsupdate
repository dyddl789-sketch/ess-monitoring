<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ESS 최신 정보 - ESS-M.S</title>
    <link rel="stylesheet" href="scc/1.main.css">
</head>
<body>

    <header>
        <div class="container">
            <h1 class="logo" onclick="location.href='1.main.html'" style="cursor:pointer;">ESS-M.S</h1>
            <nav>
                <ul>
                    <li><a href="1.main.html">홈</a></li>
                    <li><a href="3.serviceInfo.html">서비스 소개</a></li>
                    <li><a href="2.contact.html">문의게시판</a></li>
                    <li id="auth-menu">
                        <a href="javascript:void(0)" class="login-btn" onclick="openLoginWindow()">로그인</a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <section class="sub-hero">
        <div class="container">
            <h2>ESS 최신 정보</h2>
            <p>에너지 저장 장치(ESS) 시장의 최신 트렌드와 기술 정보를 전해드립니다.</p>
        </div>
    </section>

    <main class="container board">
        <div class="board-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <p>총 <strong>4</strong>개의 소식이 있습니다.</p>
            <div class="search-box">
                <input type="text" placeholder="검색어 입력" style="padding: 5px; border: 1px solid #ddd; border-radius: 4px;">
                <button class="btn" style="padding: 5px 15px; margin: 0;">검색</button>
            </div>
        </div>

        <table class="board-table">
            <thead>
                <tr>
                    <th style="width: 80px; text-align: center;">번호</th>
                    <th>제목</th>
                    <th style="width: 120px;">작성일</th>
                    <th style="width: 80px; text-align: center;">조회</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="text-align: center;">4</td>
                    <td>
                <a href="7.news_view.html" style="text-decoration: none; color: #333; font-weight: bold;"> [기술] 차세대 배터리 매니지먼트 시스템(BMS) 효율 측정 결과</a>
                    </td>
                    <td>2024-03-20</td>
                    <td style="text-align: center;">125</td>
                </tr>
                <tr>
                    <td style="text-align: center;">3</td>
                    <td>
                        <a href="7.news_view.html" style="text-decoration: none; color: #333; font-weight: bold;">
                            [공지] ESS-M.S 모니터링 시스템 정기 점검 안내 (3/25)
                        </a>
                    </td>
                    <td>2024-03-18</td>
                    <td style="text-align: center;">48</td>
                </tr>
                <tr>
                    <td style="text-align: center;">2</td>
                    <td><a href="7.news_view.html" style="text-decoration: none; color: #333; font-weight: bold;">[업계] 2024년 상반기 에너지 정책 변화와 ESS 시장 전망</a></td>
                    <td>2024-03-15</td>
                    <td style="text-align: center;">210</td>
                </tr>
                <tr>
                    <td style="text-align: center;">1</td>
                    <td><a href="7.news_view.html" style="text-decoration: none; color: #333; font-weight: bold;">[보도] 당사 모니터링 시스템, 에너지 효율 대상 수상</a></td>
                    <td>2024-03-10</td>
                    <td style="text-align: center;">89</td>
                </tr>
            </tbody>
        </table>

        <div class="pagination" style="text-align: center; margin-top: 30px;">
            <a href="#" style="margin: 0 5px; text-decoration: none; color: #007bff; font-weight: bold;">1</a>
        </div>
    </main>

    <script>
        function openLoginWindow() {
            const width = 450; const height = 620;
            const left = (window.screen.width / 2) - (width / 2);
            const top = (window.screen.height / 2) - (height / 2);
            window.open('4.login.html', 'ESS_Login', `width=${width}, height=${height}, left=${left}, top=${top}, resizable=no, scrollbars=no`);
        }
    </script>

    <!-- 로그인 체크기능 -->
    <script>
// 페이지 로드 시 실행
window.onload = function() {
    checkLoginStatus();
};

function checkLoginStatus() {
    const isLoggedIn = localStorage.getItem('isLoggedIn'); // 로그인 상태 확인
    const authMenu = document.getElementById('auth-menu');

    if (isLoggedIn === 'true') {
        const userName = localStorage.getItem('userName') || '사용자';
        // 로그인 상태일 때: '님' 표기 및 로그아웃 버튼 표시
        authMenu.innerHTML = `
            <span style="margin-right:15px; color:#333; font-weight:bold;">${userName}님</span>
            <a href="javascript:void(0)" class="login-btn" style="background:#6c757d;" onclick="handleLogout()">로그아웃</a>
        `;
    }
}

function handleLogout() {
    if(confirm("로그아웃 하시겠습니까?")) {
        localStorage.removeItem('isLoggedIn');
        localStorage.removeItem('userName');
        alert("로그아웃 되었습니다.");
        location.reload(); // 페이지 새로고침하여 메뉴 갱신
    }
}

// 기존에 만든 로그인 창 열기 함수
function openLoginWindow() {
    const width = 450; const height = 620;
    const left = (window.screen.width / 2) - (width / 2);
    const top = (window.screen.height / 2) - (height / 2);
    window.open('4.login.html', 'ESS_Login', `width=${width}, height=${height}, left=${left}, top=${top}, resizable=no, scrollbars=no`);
}
</script>
 
</body>
</html>
